# ─────────────────────────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-50-char-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://pagae:pagae@localhost:5432/pagae

# ─────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# Integrations (fill in when available)
# ─────────────────────────────────────────────────────────────────
CELCOIN_CLIENT_ID=
CELCOIN_CLIENT_SECRET=
CELCOIN_BASE_URL=https://sandbox.openfinance.celcoin.dev

SERASA_API_KEY=
SERASA_BASE_URL=https://api.serasaexperian.com.br

CAF_API_KEY=
CAF_BASE_URL=https://api.caf.io

# ─────────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io

BREVO_API_KEY=
DEFAULT_FROM_EMAIL=noreply@pagae.com.br

# ─────────────────────────────────────────────────────────────────
# AWS (production only)
# ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=pagae-documents
AWS_S3_REGION_NAME=sa-east-1

# ─────────────────────────────────────────────────────────────────
# Sentry (production only)
# ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
