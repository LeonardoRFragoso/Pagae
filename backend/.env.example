# ─────────────────────────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-50-char-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
VERSION=1.0.0

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://pagae:pagae@localhost:5432/pagae
# Alternativa: DB_NAME, DB_USER, DB_PASSWORD, DB_HOST, DB_PORT

# ─────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─────────────────────────────────────────────────────────────────
# CORS / CSRF
# ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# Public URLs
# ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────
# Proxy / SSL (Railway/Vercel)
# ─────────────────────────────────────────────────────────────────
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_SSL=True
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ─────────────────────────────────────────────────────────────────
# Provider (sandbox = default, celcoin only with real credentials)
# ─────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=sandbox
CELCOIN_CLIENT_ID=
CELCOIN_CLIENT_SECRET=
CELCOIN_BASE_URL=https://sandbox.openfinance.celcoin.dev

SERASA_API_KEY=
SERASA_BASE_URL=https://api.serasaexperian.com.br

CAF_API_KEY=
CAF_BASE_URL=https://api.caf.io

# ─────────────────────────────────────────────────────────────────
# Notifications
# ─────────────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io

BREVO_API_KEY=
DEFAULT_FROM_EMAIL=noreply@pagae.com.br

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# ─────────────────────────────────────────────────────────────────
# AWS (production/staging optional)
# ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=sa-east-1

# ─────────────────────────────────────────────────────────────────
# Sentry (production/staging optional)
# ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
